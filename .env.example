# Copie para `.env` na raiz (`cp .env.example .env`) e ajuste os valores.
# O `.env` está no .gitignore e é carregado em runtime pelo flutter_dotenv.

# URL base do backend Vanep (Spring Authorization Server), SEM sufixo /api.
# Dev (web/desktop): http://localhost:8080
# Emulador Android: use http://10.0.2.2:8080 (10.0.2.2 = "localhost" do host visto pelo emulador).
# Dispositivo físico: use o IP da sua máquina na rede (ex.: http://192.168.0.10:8080).
AUTH_URL=http://10.0.2.2:8080

# Client OAuth público do mobile (PKCE, sem secret).
# Deve bater com VANEP_OAUTH_MOBILE_CLIENT_ID no vanep-api-java.
OAUTH_CLIENT_ID=vanep-mobile

# Redirect custom-scheme registrado no backend (VANEP_OAUTH_MOBILE_REDIRECT_URIS).
# É interceptado dentro do WebView — não precisa de intent-filter/deep link nativo.
OAUTH_REDIRECT_URI=com.vanep.vanepmobile://oauth2redirect

# Scopes solicitados no authorize (separados por espaço).
OAUTH_SCOPES=read write
